# Local development
PORT=8080
VITE_LLM_PROXY_URL=/chat

# Google Cloud Run / Vertex AI default
APP_ENV=production
AI_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=sei-ufg-nuvem-ndh
GOOGLE_CLOUD_LOCATION=global
VERTEX_MODEL=gemini-2.5-pro
VERTEX_MAX_OUTPUT_TOKENS=4096
VERTEX_TEMPERATURE=0.2
MAX_BODY_BYTES=2000000

# Optional institutional proxy
# PROVIDER_URL=https://example.edu.br/llm/chat
# PROVIDER_API_KEY=

# Optional OpenAI fallback, preferably from Secret Manager in Cloud Run
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.2
# OPENAI_MAX_OUTPUT_TOKENS=2500

# Optional CORS if frontend is hosted elsewhere
# CORS_ORIGIN=https://revisor.example.edu.br
